# Copy to .env.local and fill in.
#
# 1) Kakao Local REST API key
#    https://developers.kakao.com/ → 내 애플리케이션 → REST API 키
VITE_KAKAO_REST_KEY=

# 2) Firebase web app config
#    Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 웹앱 추가 후 config 붙여넣기
#    (reuses the daligo-e4dd3 project; create a new Web app under it)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=daligo-e4dd3.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=daligo-e4dd3
VITE_FIREBASE_STORAGE_BUCKET=daligo-e4dd3.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
